# 版本控制
.git/
.gitignore

# Python 虚拟环境与缓存
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage

# Node 依赖与构建产物
node_modules/
web/node_modules/
web/dist/

# 密钥（不烘焙进镜像）
.env

# 数据库（不烘焙进镜像）
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Docker 自身
Dockerfile
docker-compose.yml
.dockerignore

# 文档、测试与报告不烘焙进运行时镜像
docs/
tests/
reports/

# IDE / 系统 文件
.vscode/
.idea/
.DS_Store
