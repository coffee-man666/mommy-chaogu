/* Mommy Chaogu TUI 全局样式
   深色主题，沉浸式体验 */

Screen {
    background: $surface;
    color: $text;
}

Widget {
    scrollbar-size: 1 1;
}

/* Markdown 渲染样式 */
Markdown {
    padding: 0 1;
}

Markdown > .markdown--code {
    background: $boost;
    color: $text;
}

Markdown > .markdown--block {
    margin: 0 0 1 0;
}
